// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core Entities
model User {
  id          String   @id @default(uuid())
  username    String   @unique
  email       String   @unique
  password    String
  firstName   String
  lastName    String
  phoneNumber String?
  role        UserRole
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  employee      Employee?
  sessions      UserSession[]
  twoFactorAuth TwoFactorAuth?

  @@map("users")
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  hod       Employee? @relation("DepartmentHOD", fields: [hodId], references: [id])
  hodId     String?   @unique
  programs  Program[]
  courses   Course[]
  students  Student[]
  employees Employee[] @relation("EmployeeDepartment")

  @@map("departments")
}

model Program {
  id               String   @id @default(uuid())
  name             String
  type             ProgramType
  duration         Int // in years
  semestersPerYear Int
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String
  hod          Employee?  @relation("ProgramHOD", fields: [hodId], references: [id])
  hodId        String?    @unique
  courses      Course[]
  students     Student[]
  feeStructures FeeStructure[]
  admissionApplications AdmissionApplication[]

  @@map("programs")
}

model Course {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  creditValue Int
  semester    Int
  level       Int
  batch       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  lecturer     Employee?   @relation(fields: [lecturerId], references: [id])
  lecturerId   String?
  department   Department  @relation(fields: [departmentId], references: [id])
  departmentId String
  program      Program     @relation(fields: [programId], references: [id])
  programId    String
  grades       Grade[]
  attendance   Attendance[]

  @@map("courses")
}

model Student {
  id               String        @id @default(uuid())
  studentId        String        @unique
  firstName        String
  lastName         String
  nationalIdName   String
  gender           Gender
  placeOfBirth     String
  dateOfBirth      DateTime
  motherName       String
  fatherName       String
  address          String
  phoneNumber      String
  email            String        @unique
  session          Session
  level            Int
  batch            String
  registrationDate DateTime
  tuitionStatus    TuitionStatus @default(UNPAID)
  profileImageUrl  String?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  program    Program     @relation(fields: [programId], references: [id])
  programId  String
  department Department  @relation(fields: [departmentId], references: [id])
  departmentId String
  grades     Grade[]
  attendance Attendance[]
  payments   Payment[]
  idCards    IDCard[]

  @@map("students")
}

model Employee {
  id          String      @id @default(uuid())
  employeeId  String      @unique
  firstName   String
  lastName    String
  email       String      @unique
  phoneNumber String
  role        EmployeeRole
  hireDate    DateTime
  salary      Decimal
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  user         User?       @relation(fields: [userId], references: [id])
  userId       String?     @unique
  department   Department? @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  departmentId String?
  courses      Course[]
  branches     Branch[]
  
  // HOD Relations
  departmentAsHOD Department? @relation("DepartmentHOD")
  programAsHOD    Program?    @relation("ProgramHOD")

  @@map("employees")
}

model Branch {
  id             String   @id @default(uuid())
  name           String
  address        String
  phoneNumber    String
  email          String
  isActive       Boolean  @default(true)
  establishedDate DateTime
  studentCount   Int      @default(0)
  staffCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  manager   Employee @relation(fields: [managerId], references: [id])
  managerId String

  @@map("branches")
}

model Batch {
  id          String   @id @default(uuid())
  name        String   @unique
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("batches")
}

// Academic Records
model Grade {
  id           String   @id @default(uuid())
  caScore      Decimal
  examScore    Decimal
  totalScore   Decimal
  grade        String
  gpa          Decimal
  semester     Int
  academicYear String
  batch        String
  recordedDate DateTime @default(now())
  recordedBy   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  student   Student @relation(fields: [studentId], references: [id])
  studentId String
  course    Course  @relation(fields: [courseId], references: [id])
  courseId  String

  @@map("grades")
}

model Attendance {
  id         String           @id @default(uuid())
  date       DateTime
  status     AttendanceStatus
  method     AttendanceMethod
  timestamp  DateTime         @default(now())
  batch      String
  recordedBy String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  // Relations
  student   Student @relation(fields: [studentId], references: [id])
  studentId String
  course    Course  @relation(fields: [courseId], references: [id])
  courseId  String

  @@map("attendance")
}

// Financial Management
model FeeStructure {
  id             String   @id @default(uuid())
  level          Int
  batch          String
  tuitionFee     Decimal
  registrationFee Decimal
  examFee        Decimal
  libraryFee     Decimal
  totalFee       Decimal
  currency       String   @default("XAF")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  program   Program @relation(fields: [programId], references: [id])
  programId String

  @@map("fee_structures")
}

model Payment {
  id            String        @id @default(uuid())
  amount        Decimal
  currency      String        @default("XAF")
  paymentMethod PaymentMethod
  paymentType   PaymentType
  status        PaymentStatus @default(PENDING)
  paymentDate   DateTime
  reference     String        @unique
  batch         String
  processedBy   String
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  student   Student @relation(fields: [studentId], references: [id])
  studentId String

  @@map("payments")
}

model OfficeAccount {
  id          String            @id @default(uuid())
  type        TransactionType
  category    String
  amount      Decimal
  description String
  date        DateTime
  reference   String            @unique
  batch       String
  createdBy   String
  approvedBy  String?
  status      TransactionStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("office_accounts")
}

// Communication
model Announcement {
  id             String              @id @default(uuid())
  title          String
  content        String
  targetAudience AnnouncementAudience
  targetGroups   Json?
  targetBatch    String?
  priority       Priority            @default(MEDIUM)
  status         AnnouncementStatus  @default(DRAFT)
  scheduledFor   DateTime?
  createdBy      String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@map("announcements")
}

model Message {
  id             String        @id @default(uuid())
  title          String
  content        String
  type           MessageType
  targetAudience String
  targetBatch    String?
  recipients     Int
  status         MessageStatus @default(DRAFT)
  scheduledFor   DateTime?
  sentAt         DateTime?
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("messages")
}

// Admissions
model AdmissionApplication {
  id              String            @id @default(uuid())
  applicantName   String
  email           String
  phoneNumber     String
  documents       Json
  status          ApplicationStatus @default(PENDING)
  applicationDate DateTime
  batch           String
  feesPaid        Boolean           @default(false)
  reviewedBy      String?
  reviewDate      DateTime?
  comments        String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  program   Program @relation(fields: [programId], references: [id])
  programId String

  @@map("admission_applications")
}

// Security & Access Control
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  permissions Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model Permission {
  id          String @id @default(uuid())
  name        String @unique
  description String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("permissions")
}

model UserSession {
  id           String   @id @default(uuid())
  role         String
  loginTime    DateTime @default(now())
  lastActivity DateTime @default(now())
  ipAddress    String
  userAgent    String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@map("user_sessions")
}

model TwoFactorAuth {
  id          String    @id @default(uuid())
  isEnabled   Boolean   @default(false)
  method      TwoFactorMethod
  backupCodes Json
  lastUsed    DateTime?
  setupDate   DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  @@map("two_factor_auth")
}

// ID Cards & Documents
model IDCard {
  id         String     @id @default(uuid())
  type       IDCardType
  holderName String
  holderId   String
  cardNumber String     @unique
  issueDate  DateTime
  expiryDate DateTime?
  template   String
  qrCode     String
  status     IDCardStatus @default(ACTIVE)
  batch      String?
  issuedBy   String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Relations
  student   Student? @relation(fields: [studentId], references: [id])
  studentId String?

  @@map("id_cards")
}

// System Configuration
model SystemSettings {
  id                      String   @id @default(uuid())
  currentBatch            String
  schoolName              String
  schoolAddress           String
  schoolPhone             String
  schoolEmail             String
  currency                String   @default("XAF")
  timezone                String   @default("Africa/Douala")
  academicYearStart       DateTime
  academicYearEnd         DateTime
  gradePassingMark        Int      @default(50)
  maxStudentsPerClass     Int      @default(50)
  enableQRAttendance      Boolean  @default(true)
  enableSMSNotifications  Boolean  @default(true)
  enableEmailNotifications Boolean @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("system_settings")
}

// Enums
enum UserRole {
  SUPER_ADMIN
  ADMIN
  LECTURER
  ACCOUNTANT
  DEAN_OF_STUDIES
  HEAD_OF_DEPARTMENT
}

enum EmployeeRole {
  HOD
  LECTURER
  ADMIN
  ACCOUNTANT
  STAFF
  DEAN
}

enum ProgramType {
  HND
  BACHELOR
  MASTERS
}

enum Gender {
  MALE
  FEMALE
}

enum Session {
  DAY
  EVENING
}

enum TuitionStatus {
  PAID
  PARTIAL
  UNPAID
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum AttendanceMethod {
  MANUAL
  QR_CODE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  ONLINE
}

enum PaymentType {
  TUITION
  REGISTRATION
  EXAM
  LIBRARY
  OTHER
}

enum PaymentStatus {
  COMPLETED
  PENDING
  FAILED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AnnouncementAudience {
  ALL
  STUDENTS
  STAFF
  PARENTS
  SPECIFIC
}

enum AnnouncementStatus {
  DRAFT
  SCHEDULED
  SENT
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum MessageType {
  SMS
  EMAIL
}

enum MessageStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TwoFactorMethod {
  SMS
  EMAIL
  AUTHENTICATOR
}

enum IDCardType {
  STUDENT
  EMPLOYEE
  ADMIT
  CERTIFICATE
}

enum IDCardStatus {
  ACTIVE
  EXPIRED
  REVOKED
}