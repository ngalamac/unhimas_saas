{
  "name": "unhimas-backend",
  "version": "1.0.0",
  "main": "src/server.ts",
  "scripts": {
    "dev": "cross-env PORT=5000 ts-node src/server.ts",
    "build": "tsc -p ./tsconfig.json",
    "start": "node ./dist/server.js",
    "test": "vitest run --reporter=default",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:reset:dry": "ts-node scripts/reset_database.ts --dry-run",
    "db:reset:soft": "ts-node scripts/reset_database.ts --apply -y",
    "db:reset:hard": "ts-node scripts/reset_database.ts --mode=hard --apply -y"
  },
  "dependencies": {
  "csv-parser": "^3.2.0",
    "@types/archiver": "^6.0.3",
    "@types/axios": "^0.9.36",
    "@types/nodemailer": "^7.0.1",
    "archiver": "^7.0.1",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.1.0",
    "dotenv": "^17.2.1",
    "exceljs": "^4.3.0",
    "express": "^4.18.2",
    "form-data": "^4.0.4",
    "json2csv": "^5.0.6",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.5",
    "pdfkit": "^0.13.0",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.97",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.0.0",
    "@types/pdfkit": "^0.17.2",
    "@types/supertest": "^2.0.16",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^7.0.3",
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  }
}
